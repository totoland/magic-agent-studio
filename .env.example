# Agent Studio configuration (copy to .env or set in the launchd plist)

# Port to listen on
PORT=4317

# Bind address. Default 127.0.0.1 (localhost only — expose via Cloudflare Tunnel / SSH).
# Set 0.0.0.0 to listen on the LAN — ONLY with an auth proxy in front, since the
# app has no auth and its agents can run shell/file tools.
HOST=127.0.0.1
